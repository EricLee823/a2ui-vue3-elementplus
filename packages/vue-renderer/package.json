{
  "name": "@a2ui-vue3-elementplus/vue-renderer",
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricLee823/a2ui-vue3-elementplus.git",
    "directory": "packages/vue-renderer"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "dependencies": {
    "@a2ui-vue3-elementplus/message-parser": "workspace:*",
    "@a2ui-vue3-elementplus/runtime-core": "workspace:*"
  },
  "devDependencies": {}
}
