{
  "name": "a2ui-vue3-elementplus",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricLee823/a2ui-vue3-elementplus.git"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm --filter @a2ui-vue3-elementplus/playground-vue-element-plus dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "docs:dev": "pnpm --filter @a2ui-vue3-elementplus/docs dev",
    "docs:build": "pnpm --filter @a2ui-vue3-elementplus/docs build",
    "docs:preview": "pnpm --filter @a2ui-vue3-elementplus/docs preview",
    "changeset": "changeset",
    "release:check": "changeset status --verbose",
    "version-packages": "pnpm release:check && changeset version",
    "release": "pnpm version-packages && pnpm build && changeset publish",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "element-plus": "^2.9.0",
    "jsdom": "^25.0.1",
    "sass": "^1.83.0",
    "tsup": "^8.3.5",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitepress": "^1.5.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
